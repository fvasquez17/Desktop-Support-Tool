<Window x:Class="DesktopSupportTool.UI.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="Desktop Support Tool"
        Width="1100" Height="720"
        MinWidth="900" MinHeight="600"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="False"
        Background="{StaticResource BgBrush}"
        ResizeMode="CanResize">

    <!-- Custom Window Chrome for modern title bar -->
    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="40"
                      ResizeBorderThickness="6"
                      GlassFrameThickness="0"
                      CornerRadius="0"/>
    </WindowChrome.WindowChrome>

    <Grid x:Name="RootGrid">
        <Grid.RowDefinitions>
            <RowDefinition Height="40"/>  <!-- Title bar -->
            <RowDefinition Height="*"/>   <!-- Content -->
        </Grid.RowDefinitions>

        <!-- ═══ Custom Title Bar ═══ -->
        <Border Grid.Row="0" Background="{StaticResource SidebarBrush}">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- App Icon + Title -->
                <StackPanel Grid.Column="0" Orientation="Horizontal" Margin="12,0" VerticalAlignment="Center">
                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE90F;"
                               FontSize="14" Foreground="{StaticResource AccentBrush}"
                               VerticalAlignment="Center" Margin="0,0,8,0"/>
                    <TextBlock Text="Desktop Support Tool" FontSize="13"
                               FontFamily="{StaticResource MainFont}" FontWeight="SemiBold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               VerticalAlignment="Center"/>
                    <TextBlock x:Name="HostnameLabel" FontSize="11"
                               FontFamily="{StaticResource MainFont}"
                               Foreground="{StaticResource TextTertiaryBrush}"
                               VerticalAlignment="Center" Margin="8,0,0,0"/>
                </StackPanel>

                <!-- Caption Buttons -->
                <StackPanel Grid.Column="2" Orientation="Horizontal"
                            WindowChrome.IsHitTestVisibleInChrome="True">
                    <Button Style="{StaticResource CaptionButton}" Click="MinimizeClick"
                            Content="&#xE921;" ToolTip="Minimize"/>
                    <Button Style="{StaticResource CaptionButton}" Click="MaximizeClick"
                            Content="&#xE922;" ToolTip="Maximize" x:Name="MaxBtn"/>
                    <Button Style="{StaticResource CloseButton}" Click="CloseClick"
                            Content="&#xE8BB;" ToolTip="Close to tray"
                            Foreground="{StaticResource TextSecondaryBrush}"/>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Main Content ═══ -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220"/>  <!-- Sidebar -->
                <ColumnDefinition Width="*"/>    <!-- Content -->
            </Grid.ColumnDefinitions>

            <!-- ═══ Sidebar Navigation ═══ -->
            <Border Grid.Column="0" Background="{StaticResource SidebarBrush}"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                <DockPanel>
                    <!-- Bottom: version + status -->
                    <StackPanel DockPanel.Dock="Bottom" Margin="14,0,14,14">
                        <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="0,0,0,10"/>
                        <StackPanel Orientation="Horizontal" Margin="4,0">
                            <Ellipse x:Name="StatusDot" Width="8" Height="8" Fill="{StaticResource SuccessBrush}"
                                     VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock x:Name="StatusLabel" Text="System Healthy"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       FontSize="11" VerticalAlignment="Center"/>
                        </StackPanel>
                        <TextBlock Text="v1.0.0" Foreground="{StaticResource TextTertiaryBrush}"
                                   FontSize="10" Margin="4,4,0,0"/>
                    </StackPanel>

                    <!-- Nav Items -->
                    <StackPanel Margin="0,8">
                        <!-- Section: Support Agent -->
                        <TextBlock Text="SUPPORT" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="20,8,0,4" FontFamily="{StaticResource MainFont}"/>

                        <RadioButton Style="{StaticResource NavButton}" Content="IT Support Agent"
                                     Tag="&#xE99A;" x:Name="NavAgent"
                                     Checked="Nav_Checked"/>

                        <!-- Section: Overview -->
                        <TextBlock Text="OVERVIEW" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="20,12,0,4" FontFamily="{StaticResource MainFont}"/>

                        <RadioButton Style="{StaticResource NavButton}" Content="Dashboard"
                                     Tag="&#xE80F;" x:Name="NavDashboard" IsChecked="True"
                                     Checked="Nav_Checked"/>

                        <RadioButton Style="{StaticResource NavButton}" Content="System Info"
                                     Tag="&#xE7F8;" x:Name="NavSystem"
                                     Checked="Nav_Checked"/>

                        <RadioButton Style="{StaticResource NavButton}" Content="Network"
                                     Tag="&#xE968;" x:Name="NavNetwork"
                                     Checked="Nav_Checked"/>

                        <RadioButton Style="{StaticResource NavButton}" Content="Peripherals"
                                     Tag="&#xE7F6;" x:Name="NavPeripherals"
                                     Checked="Nav_Checked"/>

                        <RadioButton Style="{StaticResource NavButton}" Content="Drivers"
                                     Tag="&#xE964;" x:Name="NavDrivers"
                                     Checked="Nav_Checked"/>

                        <RadioButton Style="{StaticResource NavButton}" Content="Services"
                                     Tag="&#xEC50;" x:Name="NavServices"
                                     Checked="Nav_Checked"/>

                        <!-- Section: Tools -->
                        <TextBlock Text="TOOLS" FontSize="10" FontWeight="Bold"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   Margin="20,16,0,4" FontFamily="{StaticResource MainFont}"/>

                        <RadioButton Style="{StaticResource NavButton}" Content="Troubleshoot"
                                     Tag="&#xE90F;" x:Name="NavTroubleshoot"
                                     Checked="Nav_Checked"/>

                        <RadioButton Style="{StaticResource NavButton}" Content="Activity Log"
                                     Tag="&#xE7C3;" x:Name="NavLog"
                                     Checked="Nav_Checked"/>
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- ═══ Content Area ═══ -->
            <Border Grid.Column="1" Padding="0">
                <ContentControl x:Name="ContentArea"/>
            </Border>
        </Grid>
    </Grid>
</Window>
