<UserControl x:Class="DesktopSupportTool.UI.Views.SystemInfoView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
        <StackPanel>

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="System Information" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource MainFont}"/>
                    <TextBlock Text="Hardware, software, and performance details"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="{StaticResource MainFont}" Margin="0,4,0,0"/>
                </StackPanel>
                <StackPanel Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}" Click="CopyAll_Click"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE8C8;"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Copy All Info" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="Refresh_Click">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE72C;" FontSize="13"/>
                    </Button>
                </StackPanel>
            </Grid>

            <!-- Machine Identity -->
            <TextBlock Text="MACHINE IDENTITY" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="Hostname" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtHostname" Text="—" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="Logged-in User" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtUsername" Text="—" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="Domain" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtDomain" Text="—" FontSize="15" FontWeight="SemiBold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="0" Grid.Row="1">
                        <TextBlock Text="Serial Number" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtSerial" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="1">
                        <TextBlock Text="Manufacturer" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtManufacturer" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Grid.Row="1">
                        <TextBlock Text="Model" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtModel" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- OS & Software -->
            <TextBlock Text="OPERATING SYSTEM" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock Text="OS Version" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtOsVersion" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="Build" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtOsBuild" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2">
                        <TextBlock Text="Activation" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtActivation" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3">
                        <TextBlock Text="Uptime" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtUptime" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Hardware -->
            <TextBlock Text="HARDWARE" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <StackPanel Grid.Column="0" Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="Processor" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtCpu" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="0" Margin="0,0,0,14">
                        <TextBlock Text="BIOS Version" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtBios" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="0" Grid.Row="1">
                        <TextBlock Text="Total RAM" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtTotalRam" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Grid.Row="1" x:Name="BatteryPanel" Visibility="Collapsed">
                        <TextBlock Text="Battery" FontSize="11" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtBattery" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- Performance / Live Metrics -->
            <TextBlock Text="PERFORMANCE" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8"/>
            <UniformGrid Columns="2" Margin="0,0,0,20">
                <!-- CPU Usage -->
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <TextBlock Text="CPU Usage" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6"/>
                        <TextBlock x:Name="TxtCpuUsage" Text="—%" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Border Height="6" CornerRadius="3" Background="{StaticResource SurfaceHighBrush}" Margin="0,8,0,0">
                            <Border x:Name="CpuUsageBar" Height="6" CornerRadius="3"
                                    Background="{StaticResource SuccessBrush}" HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- RAM Usage -->
                <Border Style="{StaticResource Card}" Margin="0,0,0,0">
                    <StackPanel>
                        <TextBlock Text="RAM Usage" FontSize="12" Foreground="{StaticResource TextSecondaryBrush}"
                                   Margin="0,0,0,6"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="TxtRamUsage" Text="—%" FontSize="28" FontWeight="Bold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                            <TextBlock x:Name="TxtRamDetail" Text="" FontSize="12"
                                       Foreground="{StaticResource TextTertiaryBrush}"
                                       VerticalAlignment="Bottom" Margin="10,0,0,4"/>
                        </StackPanel>
                        <Border Height="6" CornerRadius="3" Background="{StaticResource SurfaceHighBrush}" Margin="0,8,0,0">
                            <Border x:Name="RamUsageBar" Height="6" CornerRadius="3"
                                    Background="{StaticResource SuccessBrush}" HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Disk Usage -->
            <TextBlock Text="STORAGE" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8"/>
            <StackPanel x:Name="DiskList" Margin="0,0,0,20"/>

        </StackPanel>
    </ScrollViewer>
</UserControl>
