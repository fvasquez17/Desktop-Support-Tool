<UserControl x:Class="DesktopSupportTool.UI.Views.LogViewerView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="*"/>     <!-- Log list -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="Auto"/>
                </Grid.RowDefinitions>

                <StackPanel Grid.ColumnSpan="2">
                    <TextBlock Text="Activity Log" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource MainFont}"/>
                    <TextBlock Text="All actions and events are logged here"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="{StaticResource MainFont}" Margin="0,4,0,12"/>
                </StackPanel>

                <!-- Controls row -->
                <StackPanel Grid.Row="1" Grid.Column="0" Orientation="Horizontal">
                    <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}" Width="280"
                             TextChanged="SearchBox_TextChanged" Margin="0,0,10,0">
                        <TextBox.ToolTip>Search log entries...</TextBox.ToolTip>
                    </TextBox>
                    <TextBlock Text="Filter:" FontSize="12" VerticalAlignment="Center"
                               Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                    <ComboBox x:Name="LevelFilter" Width="100" SelectionChanged="LevelFilter_Changed"
                              VerticalAlignment="Center"/>
                </StackPanel>

                <StackPanel Grid.Row="1" Grid.Column="1" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}" Click="ExportDiagnostics_Click"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xEDE1;"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Export Diagnostics"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="OpenLogFolder_Click"
                            Margin="0,0,8,0">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xEC50;"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Open Log Folder"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}" Click="Refresh_Click">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE72C;" FontSize="13"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- Log List -->
        <Border Grid.Row="1" Margin="28,0,28,24" Style="{StaticResource Card}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto" x:Name="LogScrollViewer">
                <StackPanel x:Name="LogList" Margin="16,12"/>
            </ScrollViewer>
        </Border>
    </Grid>
</UserControl>
