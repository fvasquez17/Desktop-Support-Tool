<UserControl x:Class="DesktopSupportTool.UI.Views.ServicesView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Quick Actions -->
            <RowDefinition Height="*"/>     <!-- Service List -->
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="0" Padding="28,24,28,16">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Services" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource MainFont}"/>
                        <TextBlock Text="Manage, troubleshoot, and control Windows services"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource MainFont}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource SecondaryButton}" Click="Refresh_Click"
                                x:Name="BtnRefresh" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE72C;"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Refresh"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="OpenServicesConsole_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE713;"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Services Console"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Search + Filter -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}" Margin="0,0,10,0"
                             TextChanged="SearchBox_TextChanged"/>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                        <TextBlock Text="Status:" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                        <ComboBox x:Name="StatusFilter" Width="120" SelectionChanged="StatusFilter_Changed">
                            <ComboBoxItem Content="All" IsSelected="True"/>
                            <ComboBoxItem Content="Running"/>
                            <ComboBoxItem Content="Stopped"/>
                        </ComboBox>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock x:Name="TxtServiceCount" Text="0 services" FontSize="12"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- ═══ Common Services Quick Actions ═══ -->
        <Border Grid.Row="1" Margin="28,0,28,12"
                Style="{StaticResource Card}" Padding="16">
            <StackPanel>
                <TextBlock Text="COMMON SERVICES" FontSize="11" FontWeight="Bold"
                           Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,10"/>
                <WrapPanel x:Name="CommonServicePanel"/>
            </StackPanel>
        </Border>

        <!-- ═══ Full Service List ═══ -->
        <Border Grid.Row="2" Margin="28,0,28,24" Style="{StaticResource Card}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="ServiceList"/>
            </ScrollViewer>
        </Border>

        <!-- Loading Overlay -->
        <Border Grid.RowSpan="3" x:Name="LoadingOverlay" Visibility="Collapsed"
                Background="#80000000">
            <TextBlock Text="Loading services..." FontSize="16"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       FontFamily="{StaticResource MainFont}"/>
        </Border>
    </Grid>
</UserControl>
