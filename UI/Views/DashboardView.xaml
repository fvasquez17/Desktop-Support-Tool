<UserControl x:Class="DesktopSupportTool.UI.Views.DashboardView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
        <StackPanel>

            <!-- ═══ Header ═══ -->
            <TextBlock Text="Dashboard" FontSize="26" FontWeight="Bold"
                       Foreground="{StaticResource TextPrimaryBrush}"
                       FontFamily="{StaticResource MainFont}" Margin="0,0,0,4"/>
            <TextBlock x:Name="WelcomeText" FontSize="13"
                       Foreground="{StaticResource TextSecondaryBrush}"
                       FontFamily="{StaticResource MainFont}" Margin="0,0,0,24"/>

            <!-- ═══ Health Status Cards Row ═══ -->
            <UniformGrid Columns="5" Margin="0,0,0,20">
                <!-- CPU -->
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE950;"
                                       FontSize="14" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="CPU" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="CpuValue" Text="—%" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Border Height="4" CornerRadius="2" Background="{StaticResource SurfaceHighBrush}" Margin="0,8,0,0">
                            <Border x:Name="CpuBar" Height="4" CornerRadius="2"
                                    Background="{StaticResource SuccessBrush}" HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- RAM -->
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE964;"
                                       FontSize="14" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="RAM" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="RamValue" Text="—%" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <Border Height="4" CornerRadius="2" Background="{StaticResource SurfaceHighBrush}" Margin="0,8,0,0">
                            <Border x:Name="RamBar" Height="4" CornerRadius="2"
                                    Background="{StaticResource SuccessBrush}" HorizontalAlignment="Left"/>
                        </Border>
                    </StackPanel>
                </Border>

                <!-- Disk -->
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xEDA2;"
                                       FontSize="14" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Disk" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="DiskValue" Text="— GB" FontSize="28" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="DiskDetail" Text="free" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>
                </Border>

                <!-- Network -->
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE968;"
                                       FontSize="14" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Network" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal">
                            <Ellipse x:Name="NetStatusDot" Width="10" Height="10"
                                     Fill="{StaticResource SuccessBrush}" Margin="0,0,8,0"
                                     VerticalAlignment="Center"/>
                            <TextBlock x:Name="NetStatusText" Text="Checking..." FontSize="16"
                                       FontWeight="SemiBold" Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="NetIpText" Text="" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}" Margin="0,4,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Uptime -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE916;"
                                       FontSize="14" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Uptime" FontSize="12" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock x:Name="UptimeValue" Text="—" FontSize="22" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"/>
                        <TextBlock x:Name="UptimeDetail" Text="" FontSize="11"
                                   Foreground="{StaticResource TextTertiaryBrush}"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- ═══ Issues / Alerts ═══ -->
            <Border x:Name="AlertBanner" Style="{StaticResource Card}" Margin="0,0,0,20"
                    Visibility="Collapsed" BorderBrush="{StaticResource WarningBrush}">
                <StackPanel Orientation="Horizontal">
                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE7BA;"
                               FontSize="18" Foreground="{StaticResource WarningBrush}"
                               VerticalAlignment="Center" Margin="0,0,12,0"/>
                    <StackPanel>
                        <TextBlock Text="Issues Detected" FontSize="14" FontWeight="SemiBold"
                                   Foreground="{StaticResource WarningBrush}"/>
                        <TextBlock x:Name="AlertText" FontSize="12"
                                   Foreground="{StaticResource TextSecondaryBrush}" TextWrapping="Wrap"/>
                    </StackPanel>
                </StackPanel>
            </Border>

            <!-- ═══ Quick Launch Row ═══ -->
            <StackPanel Orientation="Horizontal" Margin="0,0,0,20">
                <Button Style="{StaticResource SecondaryButton}" Click="LaunchRdp_Click"
                        Margin="0,0,8,0" ToolTip="Remote Desktop Connection">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE8AF;"
                                   FontSize="14" VerticalAlignment="Center" Margin="0,0,6,0"
                                   Foreground="{StaticResource AccentBrush}"/>
                        <TextBlock Text="Remote Desktop" VerticalAlignment="Center"/>
                    </StackPanel>
                </Button>
            </StackPanel>

            <!-- ═══ Recent Activity ═══ -->
            <TextBlock Text="Recent Activity" FontSize="16" FontWeight="SemiBold"
                       Foreground="{StaticResource TextPrimaryBrush}" Margin="0,0,0,10"/>
            <Border Style="{StaticResource Card}">
                <StackPanel x:Name="RecentActivityList">
                    <TextBlock Text="No recent activity" FontSize="12"
                               Foreground="{StaticResource TextTertiaryBrush}"/>
                </StackPanel>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
