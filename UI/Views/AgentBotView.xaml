<UserControl x:Class="DesktopSupportTool.UI.Views.AgentBotView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>   <!-- Header -->
            <RowDefinition Height="*"/>      <!-- Chat Messages -->
            <RowDefinition Height="Auto"/>   <!-- Input Bar -->
        </Grid.RowDefinitions>

        <!-- ═══ Header ═══ -->
        <Border Grid.Row="0" Padding="28,20,28,16">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="Auto"/>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <!-- Bot Avatar -->
                <Border Grid.Column="0" Width="42" Height="42" CornerRadius="21"
                        Margin="0,0,14,0" VerticalAlignment="Center">
                    <Border.Background>
                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                            <GradientStop Color="#3B82F6" Offset="0"/>
                            <GradientStop Color="#8B5CF6" Offset="1"/>
                        </LinearGradientBrush>
                    </Border.Background>
                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE99A;"
                               FontSize="20" Foreground="White"
                               HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>

                <StackPanel Grid.Column="1" VerticalAlignment="Center">
                    <TextBlock Text="IT Support Agent" FontSize="20" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource MainFont}"/>
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource SuccessBrush}"
                                 VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Online — Ready to help" FontSize="11"
                                   Foreground="{StaticResource SuccessBrush}"
                                   FontFamily="{StaticResource MainFont}"/>
                    </StackPanel>
                </StackPanel>

                <StackPanel Grid.Column="2" Orientation="Horizontal">
                    <Button Style="{StaticResource PrimaryButton}"
                            Click="ScanSystem_Click" Margin="0,0,8,0" ToolTip="Run a live system health scan">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE9D5;"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Scan System"/>
                        </StackPanel>
                    </Button>
                    <Button Style="{StaticResource SecondaryButton}"
                            Click="ClearChat_Click" ToolTip="Clear conversation">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE74D;"
                                       FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock Text="Clear"/>
                        </StackPanel>
                    </Button>
                </StackPanel>
            </Grid>
        </Border>

        <!-- ═══ Chat Messages Area ═══ -->
        <Border Grid.Row="1" Margin="28,0,28,0"
                Background="{StaticResource SurfaceBrush}"
                CornerRadius="12" BorderBrush="{StaticResource BorderSubtleBrush}"
                BorderThickness="1">
            <ScrollViewer x:Name="ChatScrollViewer" VerticalScrollBarVisibility="Auto"
                          Padding="16,16,16,16">
                <StackPanel x:Name="ChatMessages" Margin="0,0,0,0"/>
            </ScrollViewer>
        </Border>

        <!-- ═══ Input Bar ═══ -->
        <Border Grid.Row="2" Margin="28,12,28,20">
            <Grid>
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>

                <Border Grid.Column="0" Background="{StaticResource SurfaceHighBrush}"
                        CornerRadius="12" BorderBrush="{StaticResource BorderSubtleBrush}"
                        BorderThickness="1" Padding="4">
                    <TextBox x:Name="InputBox" 
                             Background="Transparent" BorderThickness="0"
                             Foreground="{StaticResource TextPrimaryBrush}"
                             FontFamily="{StaticResource MainFont}" FontSize="14"
                             Padding="12,10" VerticalAlignment="Center"
                             AcceptsReturn="False" 
                             KeyDown="InputBox_KeyDown"
                             TextWrapping="Wrap"
                             MaxHeight="80"
                             CaretBrush="{StaticResource AccentBrush}">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="8"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                </Border>

                <!-- Watermark text -->
                <TextBlock Grid.Column="0" Text="Describe your issue... (e.g., 'Outlook keeps crashing')"
                           FontSize="13" Foreground="{StaticResource TextTertiaryBrush}"
                           FontFamily="{StaticResource MainFont}"
                           IsHitTestVisible="False" Padding="20,14"
                           x:Name="InputPlaceholder" VerticalAlignment="Center"/>

                <Button Grid.Column="1" Margin="10,0,0,0" Click="Send_Click"
                        x:Name="BtnSend" Padding="16,12" ToolTip="Send message">
                    <Button.Style>
                        <Style TargetType="Button" BasedOn="{StaticResource PrimaryButton}">
                            <Style.Triggers>
                                <Trigger Property="IsEnabled" Value="False">
                                    <Setter Property="Opacity" Value="0.5"/>
                                </Trigger>
                            </Style.Triggers>
                        </Style>
                    </Button.Style>
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE724;"
                                   FontSize="16" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Send" FontSize="13"/>
                    </StackPanel>
                </Button>
            </Grid>
        </Border>
    </Grid>
</UserControl>
