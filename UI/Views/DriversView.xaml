<UserControl x:Class="DesktopSupportTool.UI.Views.DriversView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>  <!-- Header -->
            <RowDefinition Height="Auto"/>  <!-- Problem devices -->
            <RowDefinition Height="*"/>     <!-- Driver list -->
        </Grid.RowDefinitions>

        <!-- Header -->
        <Border Grid.Row="0" Padding="28,24,28,16">
            <StackPanel>
                <Grid Margin="0,0,0,16">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel>
                        <TextBlock Text="Drivers" FontSize="26" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}"
                                   FontFamily="{StaticResource MainFont}"/>
                        <TextBlock Text="View, troubleshoot, and manage device drivers"
                                   FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                                   FontFamily="{StaticResource MainFont}" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1" Orientation="Horizontal">
                        <Button Style="{StaticResource PrimaryButton}" Click="ExportDriverList_Click"
                                Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xEDE1;"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Export Report"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="ScanHardware_Click"
                                x:Name="BtnScanHw" Margin="0,0,8,0">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE895;"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Scan Hardware"/>
                            </StackPanel>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="OpenDeviceManager_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE713;"
                                           FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                                <TextBlock Text="Device Manager"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Grid>

                <!-- Search + Filter -->
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <TextBox x:Name="SearchBox" Style="{StaticResource SearchBox}" Margin="0,0,10,0"
                             TextChanged="SearchBox_TextChanged">
                        <TextBox.ToolTip>Search drivers by name, manufacturer...</TextBox.ToolTip>
                    </TextBox>
                    <StackPanel Grid.Column="1" Orientation="Horizontal" Margin="0,0,10,0">
                        <TextBlock Text="Class:" FontSize="12" VerticalAlignment="Center"
                                   Foreground="{StaticResource TextSecondaryBrush}" Margin="0,0,6,0"/>
                        <ComboBox x:Name="ClassFilter" Width="150" SelectionChanged="ClassFilter_Changed"/>
                    </StackPanel>
                    <StackPanel Grid.Column="2" Orientation="Horizontal">
                        <TextBlock x:Name="TxtDriverCount" Text="0 drivers" FontSize="12"
                                   Foreground="{StaticResource TextTertiaryBrush}"
                                   VerticalAlignment="Center"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <!-- Problem Devices Banner -->
        <Border Grid.Row="1" x:Name="ProblemBanner" Visibility="Collapsed"
                Background="#1A1C0E0E" Margin="28,0,28,12"
                CornerRadius="12" Padding="20"
                BorderBrush="{StaticResource ErrorBrush}" BorderThickness="1">
            <StackPanel>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE7BA;"
                               FontSize="18" Foreground="{StaticResource ErrorBrush}"
                               VerticalAlignment="Center" Margin="0,0,10,0"/>
                    <TextBlock x:Name="TxtProblemCount" Text="Problem Devices"
                               FontSize="15" FontWeight="SemiBold"
                               Foreground="{StaticResource ErrorBrush}"
                               VerticalAlignment="Center"/>
                </StackPanel>
                <StackPanel x:Name="ProblemDeviceList"/>
            </StackPanel>
        </Border>

        <!-- Driver List -->
        <Border Grid.Row="2" Margin="28,0,28,24" Style="{StaticResource Card}" Padding="0">
            <ScrollViewer VerticalScrollBarVisibility="Auto">
                <StackPanel x:Name="DriverList" Margin="0"/>
            </ScrollViewer>
        </Border>

        <!-- Status overlay -->
        <Border Grid.RowSpan="3" x:Name="LoadingOverlay" Visibility="Collapsed"
                Background="#80000000">
            <StackPanel VerticalAlignment="Center" HorizontalAlignment="Center">
                <TextBlock Text="Loading drivers..." FontSize="16"
                           Foreground="{StaticResource TextPrimaryBrush}"
                           HorizontalAlignment="Center" FontFamily="{StaticResource MainFont}"/>
            </StackPanel>
        </Border>
    </Grid>
</UserControl>
