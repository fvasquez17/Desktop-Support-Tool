<UserControl x:Class="DesktopSupportTool.UI.Views.NetworkView"
             xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
             xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
             Background="{StaticResource BgBrush}">

    <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="28,24">
        <StackPanel>

            <!-- Header -->
            <Grid Margin="0,0,0,24">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="*"/>
                    <ColumnDefinition Width="Auto"/>
                </Grid.ColumnDefinitions>
                <StackPanel>
                    <TextBlock Text="Network Information" FontSize="26" FontWeight="Bold"
                               Foreground="{StaticResource TextPrimaryBrush}"
                               FontFamily="{StaticResource MainFont}"/>
                    <TextBlock Text="Connectivity, diagnostics, and network tools"
                               FontSize="13" Foreground="{StaticResource TextSecondaryBrush}"
                               FontFamily="{StaticResource MainFont}" Margin="0,4,0,0"/>
                </StackPanel>
                <Button Grid.Column="1" Style="{StaticResource SecondaryButton}" Click="Refresh_Click">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE72C;"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Refresh"/>
                    </StackPanel>
                </Button>
            </Grid>

            <!-- Connection Info Cards -->
            <UniformGrid Columns="3" Margin="0,0,0,20">
                <!-- IP / Adapter -->
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE968;"
                                       FontSize="16" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Connection" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="IP Address" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtIp" Text="—" FontSize="18" FontWeight="Bold"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,8"/>
                        <TextBlock Text="Subnet" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtSubnet" Text="—" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,8"/>
                        <TextBlock Text="Gateway" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtGateway" Text="—" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,8"/>
                        <TextBlock Text="MAC Address" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtMac" Text="—" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>

                <!-- Domain / DNS -->
                <Border Style="{StaticResource Card}" Margin="0,0,10,0">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE774;"
                                       FontSize="16" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="Domain &amp; DNS" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Domain" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
                            <Ellipse x:Name="DomainDot" Width="8" Height="8"
                                     Fill="{StaticResource TextTertiaryBrush}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtDomain" Text="—" FontSize="14" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="DNS Servers" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtDns" Text="—" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,8"
                                   TextWrapping="Wrap"/>
                        <TextBlock Text="Adapter" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtAdapter" Text="—" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"
                                   TextWrapping="Wrap"/>
                    </StackPanel>
                </Border>

                <!-- VPN / Wi-Fi -->
                <Border Style="{StaticResource Card}">
                    <StackPanel>
                        <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                            <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE705;"
                                       FontSize="16" Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" Margin="0,0,8,0"/>
                            <TextBlock Text="VPN &amp; Wi-Fi" FontSize="13" FontWeight="SemiBold"
                                       Foreground="{StaticResource TextSecondaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="VPN Status" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <StackPanel Orientation="Horizontal" Margin="0,2,0,8">
                            <Ellipse x:Name="VpnDot" Width="8" Height="8"
                                     Fill="{StaticResource TextTertiaryBrush}"
                                     VerticalAlignment="Center" Margin="0,0,6,0"/>
                            <TextBlock x:Name="TxtVpn" Text="Not connected" FontSize="14"
                                       Foreground="{StaticResource TextPrimaryBrush}"/>
                        </StackPanel>
                        <TextBlock Text="Wi-Fi SSID" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                   x:Name="WifiSsidLabel"/>
                        <TextBlock x:Name="TxtWifiSsid" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,8"/>
                        <TextBlock Text="Signal Strength" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"
                                   x:Name="WifiSignalLabel"/>
                        <TextBlock x:Name="TxtWifiSignal" Text="—" FontSize="14"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,8"/>
                        <TextBlock Text="Speed" FontSize="10" Foreground="{StaticResource TextTertiaryBrush}"/>
                        <TextBlock x:Name="TxtSpeed" Text="—" FontSize="13"
                                   Foreground="{StaticResource TextPrimaryBrush}" Margin="0,2,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>

            <!-- Ping Test -->
            <TextBlock Text="PING TEST" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8"/>
            <Border Style="{StaticResource Card}" Margin="0,0,0,20">
                <StackPanel>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,12">
                        <Button Style="{StaticResource PrimaryButton}" Click="PingGoogle_Click"
                                x:Name="BtnPingGoogle" Margin="0,0,8,0">
                            <TextBlock Text="Ping Google (8.8.8.8)"/>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="PingGateway_Click"
                                x:Name="BtnPingGateway" Margin="0,0,8,0">
                            <TextBlock Text="Ping Gateway"/>
                        </Button>
                        <Button Style="{StaticResource SecondaryButton}" Click="PingCustom_Click"
                                x:Name="BtnPingCustom">
                            <TextBlock Text="Ping Custom"/>
                        </Button>
                        <TextBox x:Name="TxtCustomHost" Style="{StaticResource SearchBox}"
                                 Width="200" Margin="8,0,0,0"
                                 Text="dc01.domain.local" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel x:Name="PingResults"/>
                </StackPanel>
            </Border>

            <!-- Action Buttons -->
            <TextBlock Text="NETWORK TOOLS" FontSize="11" FontWeight="Bold"
                       Foreground="{StaticResource TextTertiaryBrush}" Margin="0,0,0,8"/>
            <WrapPanel Margin="0,0,0,20">
                <Button Style="{StaticResource PrimaryButton}" Click="FlushDns_Click" Margin="0,0,8,8"
                        x:Name="BtnFlushDns">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE72C;"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Flush DNS"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource PrimaryButton}" Click="RenewIp_Click" Margin="0,0,8,8"
                        x:Name="BtnRenewIp">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE968;"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Renew IP"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}" Click="ResetStack_Click" Margin="0,0,8,8"
                        x:Name="BtnResetStack">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE90F;"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Reset Network Stack"/>
                    </StackPanel>
                </Button>
                <Button Style="{StaticResource SecondaryButton}" Click="OpenSettings_Click" Margin="0,0,8,8">
                    <StackPanel Orientation="Horizontal">
                        <TextBlock FontFamily="{StaticResource IconFont}" Text="&#xE713;"
                                   FontSize="13" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="Network Settings"/>
                    </StackPanel>
                </Button>
            </WrapPanel>

            <!-- Status feedback -->
            <Border x:Name="StatusBanner" Style="{StaticResource Card}" Visibility="Collapsed"
                    Margin="0,0,0,10">
                <TextBlock x:Name="StatusText" FontSize="13" TextWrapping="Wrap"
                           Foreground="{StaticResource TextPrimaryBrush}"/>
            </Border>

        </StackPanel>
    </ScrollViewer>
</UserControl>
